generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model FooterFormSubmission {
  id              String   @id @default(cuid())
  nomeCompleto    String
  email           String
  whatsapp        String
  assuntoDesejado String
  termos          Boolean
  status          String?
  timestamp       DateTime @default(now())

  @@map("footer_form_submissions")
}
