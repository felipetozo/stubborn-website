generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model FooterFormSubmission {
  id              String   @id @default(cuid())
  nomeCompleto    String
  email           String
  whatsapp        String
  assuntoDesejado String
  termos          Boolean
  status          String?
  timestamp       DateTime @default(now())

  @@map("footer_form_submissions")
}

model BlogPost {
  id              String    @id @default(uuid())
  slug            String    @unique
  title           String
  excerpt         String?
  content         String    @db.Text
  category        String?
  tags            String[]  @default([])
  coverImage      String?   @map("cover_image")
  coverAlt        String?   @map("cover_alt")
  readTimeMinutes Int?      @map("read_time_minutes")
  authorName      String    @default("Equipe") @map("author_name")
  authorTitle     String?   @map("author_title")
  authorImage     String?   @map("author_image")
  destaque        Boolean   @default(false)
  status          String    @default("rascunho") // publicado | rascunho | agendado
  published       Boolean   @default(false)
  publishedAt     DateTime? @map("published_at")
  metaTitle       String?   @map("meta_title")
  metaDescription String?   @map("meta_description")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([slug])
  @@index([status, publishedAt])
  @@map("blog_posts")
}

model AnalyticsVisitor {
  id           String    @id
  firstSeen    DateTime  @default(now()) @map("first_seen")
  lastSeen     DateTime  @default(now()) @map("last_seen")
  visitCount   Int       @default(1) @map("visit_count")
  lastIp       String?   @map("last_ip")
  userAgent    String?   @map("user_agent")
  language     String?
  timezone     String?
  screen       String?
  displayName  String?   @map("display_name")
  leadKey      String?   @map("lead_key")
  identifiedAt DateTime? @map("identified_at")
  pageviews    AnalyticsPageview[]
  events       AnalyticsEvent[]

  @@map("analytics_visitor")
}

model AnalyticsPageview {
  id             Int              @id @default(autoincrement())
  visitorId      String           @map("visitor_id")
  visitor        AnalyticsVisitor @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  sessionKey     String?          @map("session_key")
  path           String
  title          String?
  referrer       String?
  referrerDomain String?          @map("referrer_domain")
  referrerSrc    String?          @map("referrer_src")
  isMobile       Boolean          @default(false) @map("is_mobile")
  utmSource      String?          @map("utm_source")
  utmMedium      String?          @map("utm_medium")
  utmCampaign    String?          @map("utm_campaign")
  utmContent     String?          @map("utm_content")
  utmTerm        String?          @map("utm_term")
  timeOnPage     Int?             @map("time_on_page")
  createdAt      DateTime         @default(now()) @map("created_at")

  @@index([visitorId])
  @@index([createdAt])
  @@index([sessionKey, path, visitorId])
  @@map("analytics_pageview")
}

model AnalyticsEvent {
  id         Int              @id @default(autoincrement())
  visitorId  String           @map("visitor_id")
  visitor    AnalyticsVisitor @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  sessionKey String?          @map("session_key")
  eventType  String           @map("event_type")
  eventLabel String?          @map("event_label")
  eventData  Json?            @map("event_data")
  path       String?
  createdAt  DateTime         @default(now()) @map("created_at")

  @@index([visitorId])
  @@index([createdAt])
  @@map("analytics_event")
}

// Stubborn Connect — log de conteúdo recebido do Admin App
model StubbornContentLog {
  id          String    @id @default(uuid())
  type        String
  content     String    @db.Text
  metadata    Json?
  publishedAt DateTime? @map("published_at")
  blogPostId  String?   @map("blog_post_id")
  action      String    @default("saved")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("stubborn_content_log")
}
